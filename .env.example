# Root environment example
# Copy to .env and fill in real secrets before running.

# GEMINI API (Google generative AI) — required for recipe/LLM features
GEMINI_API_KEY=

# MongoDB connection if not using Docker compose default
MONGO_URI=mongodb://mongo:27017/smartfridge

# Optional Google credentials path (if using Google Vision OCR)
GOOGLE_APPLICATION_CREDENTIALS=backend/google-credentials.json
